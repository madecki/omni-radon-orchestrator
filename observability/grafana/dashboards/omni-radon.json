    {
      "id": 1,
      "type": "stat",
      "title": "Gateway",
      "description": "Log lines received in the last 2 minutes. Zero means the service is silent or down.",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count_over_time({service=\"gateway\"}[2m])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": { "color": "red", "index": 0, "text": "No data" }
              }
            },
            {
              "type": "value",
              "options": {
                "0": { "color": "orange", "index": 1, "text": "Idle" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short",
          "noValue": "No data"
        },
        "overrides": []
      }
    },
